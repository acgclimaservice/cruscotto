# Routes principali
@app.route('/')
def dashboard():
    """Dashboard principale con statistiche"""
    try:
        stats = get_dashboard_stats()
        return render_template('dashboard.html', **stats)
    except Exception as e:
        app.logger.error(f"Errore dashboard: {e}")
        return render_template('dashboard.html', 
                             ddt_in_count=0, 
                             ddt_out_count=0, 
                             bozze_count=0)

