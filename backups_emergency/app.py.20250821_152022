@app.route('/api/dashboard/stats')
def api_dashboard_stats():
    """API per statistiche dashboard aggiornate"""
    try:
        stats = get_dashboard_stats()
        stats['timestamp'] = datetime.now().isoformat()
        return jsonify(stats)
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@app.route('/api/articolo/cerca/<codice>')
def cerca_articolo(codice):
    """API ricerca articolo per codice"""
    try:
        articolo = CatalogoArticolo.query.filter_by(codice_interno=codice).first()
        if articolo:
            return jsonify({
                'found': True,
                'descrizione': articolo.descrizione,
                'costo_ultimo': articolo.costo_ultimo,
                'prezzo_vendita': articolo.prezzo_vendita,
                'unita_misura': articolo.unita_misura,
                'fornitore_principale': articolo.fornitore_principale,
                'codice_produttore': articolo.codice_produttore,
                'nome_produttore': articolo.nome_produttore
            })
        return jsonify({'found': False})
    except Exception as e:
        return jsonify({'error': str(e)}), 500

