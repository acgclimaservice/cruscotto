# Inizializzazione database
def init_database():
    """Inizializza database e dati di base"""
    with app.app_context():
        db.create_all()
        
        # Verifica se il database è vuoto
        if not Magazzino.query.first():
            # Magazzini di default
            magazzini = [
                Magazzino(codice='MAG001', descrizione='Magazzino Centrale', 
                         responsabile='Admin', attivo=True),
                Magazzino(codice='MAG002', descrizione='Deposito Nord', 
                         responsabile='Admin', attivo=True),
                Magazzino(codice='MAG003', descrizione='Deposito Sud', 
                         responsabile='Admin', attivo=True)
            ]
            
            # Mastrini di default
            mastrini = [
                Mastrino(codice='ACQ001', descrizione='Acquisto Materiali', 
                        tipo='acquisto', attivo=True),
                Mastrino(codice='ACQ002', descrizione='Acquisto Attrezzature', 
                        tipo='acquisto', attivo=True),
                Mastrino(codice='VEN001', descrizione='Vendita Prodotti', 
                        tipo='ricavo', attivo=True),
                Mastrino(codice='VEN002', descrizione='Vendita Servizi', 
                        tipo='ricavo', attivo=True)
            ]
            
            # Configurazioni di default
            configurazioni = [
                ConfigurazioneSistema(chiave='azienda_nome', valore='Azienda S.r.l.', 
                                     descrizione='Nome azienda'),
                ConfigurazioneSistema(chiave='azienda_piva', valore='12345678901', 
                                     descrizione='Partita IVA'),
                ConfigurazioneSistema(chiave='backup_automatico', valore='giornaliero', 
                                     descrizione='Frequenza backup'),
                ConfigurazioneSistema(chiave='margine_default', valore='40', 
                                     descrizione='Margine % default')
            ]
            
            # Salva tutto
            for mag in magazzini:
                db.session.add(mag)
            for mast in mastrini:
                db.session.add(mast)
            for conf in configurazioni:
                db.session.add(conf)
            
            db.session.commit()
            print("Database inizializzato con successo")

